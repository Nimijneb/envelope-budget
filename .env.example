# Required in production (min 16 characters recommended)
JWT_SECRET=change-this-to-a-long-random-string

# First admin (created on startup if no user with this username exists).
# ADMIN_EMAIL is still read as a fallback for one release.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=use-a-long-random-password

# Public self-registration is OFF by default. Enable only for local dev:
# ALLOW_OPEN_REGISTRATION=true

# SQLite database file (default: ./data/envelopes.db relative to server cwd)
# DATABASE_PATH=/app/data/envelopes.db

# API port (default 4000)
# PORT=4000

# Optional: restrict browser origin (default: reflect request origin)
# CORS_ORIGIN=https://budget.example.com
